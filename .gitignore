node_modules/
dist/

# Compiled SDK artifacts must never live alongside .ts sources.
# The plugin-sdk emits to dist/; any .js/.d.ts found in src/ is stale build output.
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map
.env
.env.local
*.log
coverage/
traces/
.budget-state.json

# macOS
.DS_Store
**/.DS_Store

# Local runtime state (credential vault, session DBs — never commit)
.alduin/
.helios/

# Test artifacts produced by config-loader tests
.tmp-*

# TypeScript incremental build cache
*.tsbuildinfo

# Local config (use config.example.yaml as template)
config.yaml

# AI tooling config
.cursorrules
.cursor/

# Implementation plans (untracked — stored locally only)
docs/plans/
.alduin--sessions.db
