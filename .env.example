# ─── Alduin secrets — copy to .env, fill in values, never commit ──────────────

# Telegram
TELEGRAM_BOT_TOKEN=
# Telegram webhook secret (used for signature verification)
# TELEGRAM_WEBHOOK_SECRET=

# Provider API keys (imported into the vault by `alduin init` or migrate.ts)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Webhook security (optional — only needed in webhook mode)
ALDUIN_WEBHOOK_SECRET=

# Vault master key — only needed when keytar is not installed.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ALDUIN_VAULT_SECRET=

# Audit HMAC key — only needed when keytar is not installed.
# ALDUIN_AUDIT_HMAC_KEY=

# ─── ALDUIN_*__ path overrides ────────────────────────────────────────────────
#
# Any field in the config schema can be overridden from the environment without
# editing config.yaml.  Use double-underscore (__) as the path separator:
#
#   ALDUIN_<SECTION>__<FIELD>[__<SUBFIELD>]=<value>
#
# Examples:
#   ALDUIN_ORCHESTRATOR__MODEL=anthropic/claude-opus-4-6
#   ALDUIN_BUDGETS__DAILY_LIMIT_USD=5.0
#   ALDUIN_BUDGETS__WARNING_THRESHOLD=0.9
#   ALDUIN_ROUTING__COMPLEXITY_THRESHOLD=0.7
#   ALDUIN_ROUTING__PRE_CLASSIFIER=false
#   ALDUIN_PROVIDERS__ANTHROPIC__API_KEY_ENV=MY_CUSTOM_KEY
#   ALDUIN_EXECUTORS__CODE__MAX_TOKENS=16000
#   ALDUIN_MEMORY__HOT_TURNS=10
#   ALDUIN_MEMORY__COLD_ENABLED=true
#
# Paths are validated against the schema; unknown paths are rejected at startup.
# Values are automatically coerced to number/boolean where the schema requires it.
#
# ALDUIN_ORCHESTRATOR__MODEL=
# ALDUIN_BUDGETS__DAILY_LIMIT_USD=

# ─── Server ───────────────────────────────────────────────────────────────────
# PORT=3000

# Host/interface the webhook gateway binds on. Defaults to 127.0.0.1 so the
# endpoint is unreachable from other hosts without an explicit reverse-proxy /
# tunnel setup. Use 0.0.0.0 ONLY after confirming network-level controls.
# ALDUIN_BIND_HOST=127.0.0.1

# Environment (do not set to 'development' in production)
# NODE_ENV=production

# ─── SECURITY-SENSITIVE — understand these before enabling ────────────────────
# Comma-separated list of proxy IP addresses / CIDR blocks whose
# X-Forwarded-For header Alduin will trust. NEVER set this to "true" or "*" —
# that would let any upstream spoof the client IP and bypass per-IP rate
# limiting. Leave unset when the gateway is NOT behind a reverse proxy.
#
# Example (behind a private reverse proxy):
#   ALDUIN_TRUSTED_PROXIES=10.0.0.0/8,192.168.1.1
# ALDUIN_TRUSTED_PROXIES=

# Allow unsigned webhooks (DEVELOPMENT ONLY — never enable in production)
# ALDUIN_ALLOW_UNSIGNED=false

# Allow file:// ingestion (DEVELOPMENT ONLY — local file access is dangerous in prod)
# ALDUIN_ALLOW_LOCAL_INGESTION=false
