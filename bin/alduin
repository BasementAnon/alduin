#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# alduin — unified CLI wrapper
#
# Usage:  alduin <command> [args...]
#
# Maps project-level scripts (build, dev, test, lint, clean, etc.) to
# `npm run <script>`, and passes everything else to the Node CLI entry point.
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail

# Resolve the project root (where package.json lives)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

CMD="${1:-}"

# ── Project scripts (delegated to npm run) ────────────────────────────────────
case "$CMD" in
  build)
    shift
    exec npm run build --prefix "$PROJECT_ROOT" -- "$@"
    ;;
  build:sdk)
    shift
    exec npm run build:sdk --prefix "$PROJECT_ROOT" -- "$@"
    ;;
  dev)
    shift
    exec npm run dev --prefix "$PROJECT_ROOT" -- "$@"
    ;;
  dev:telegram)
    shift
    exec npm run dev:telegram --prefix "$PROJECT_ROOT" -- "$@"
    ;;
  test)
    shift
    exec npm run test --prefix "$PROJECT_ROOT" -- "$@"
    ;;
  test:watch)
    shift
    exec npm run test:watch --prefix "$PROJECT_ROOT" -- "$@"
    ;;
  test:coverage)
    shift
    exec npm run test:coverage --prefix "$PROJECT_ROOT" -- "$@"
    ;;
  lint)
    shift
    exec npm run lint --prefix "$PROJECT_ROOT" -- "$@"
    ;;
  clean)
    shift
    exec npm run clean --prefix "$PROJECT_ROOT" -- "$@"
    ;;
  config:generate)
    shift
    exec npm run config:generate --prefix "$PROJECT_ROOT" -- "$@"
    ;;
  config:check)
    shift
    exec npm run config:check --prefix "$PROJECT_ROOT" -- "$@"
    ;;
  # ── CLI subcommands (delegated to Node entry point) ─────────────────────────
  *)
    exec node "$PROJECT_ROOT/dist/cli.js" "$@"
    ;;
esac
